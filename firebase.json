{
  "hosting": {
    "site": "max-atacadista-pix",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/*.bat",
      "**/*.cmd",
      "**/*.exe",
      "**/*.sh",
      "**/*.ps1",
      "server.js",
      "node_modules/**",
      ".git/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
